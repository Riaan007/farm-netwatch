# Copy to .env and fill in. The .env file is gitignored — secrets stay local.

# Public DDNS name (or static IP) the farm sites dial in to.
WG_HOST=your-hub.example.com

# wg-easy admin UI password as a bcrypt hash. Generate it with:
#   docker run --rm ghcr.io/wg-easy/wg-easy:14 wgpw 'your-password-here'
# then DOUBLE every $ sign for docker compose. Example: the tool prints
#   PASSWORD_HASH='$2a$12$AbC...'   ->   write   WG_PASSWORD_HASH=$$2a$$12$$AbC...
WG_PASSWORD_HASH=

# Hub dashboard login. Seeds the password on FIRST boot only; afterwards the
# password lives in data/hub/hub.json and this var is ignored. Leave blank to
# set the password in the browser on first visit instead.
HUB_PASSWORD=

# Host port for the hub dashboard (8091 verified free on the Pi 5).
HUB_PORT=8091

# Image override: keep a locally built image instead of GHCR.
#HUB_IMAGE=farm-netwatch-hub:local

TZ=Africa/Johannesburg
